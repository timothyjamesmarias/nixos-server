{
  "__inputs": [],
  "__requires": [],
  "uid": "traefik",
  "title": "Traefik",
  "tags": ["traefik", "proxy"],
  "editable": true,
  "refresh": "30s",
  "schemaVersion": 38,
  "timezone": "browser",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Requests / s",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(traefik_entrypoint_requests_total{job=\"traefik\"}[5m])) by (entrypoint)",
          "legendFormat": "{{ entrypoint }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Error Rate (4xx/5xx %)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(traefik_entrypoint_requests_total{job=\"traefik\", code=~\"4..\"}[5m])) / sum(rate(traefik_entrypoint_requests_total{job=\"traefik\"}[5m]))",
          "legendFormat": "4xx"
        },
        {
          "expr": "sum(rate(traefik_entrypoint_requests_total{job=\"traefik\", code=~\"5..\"}[5m])) / sum(rate(traefik_entrypoint_requests_total{job=\"traefik\"}[5m]))",
          "legendFormat": "5xx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Average Response Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(traefik_entrypoint_request_duration_seconds_sum{job=\"traefik\"}[5m])) by (entrypoint) / sum(rate(traefik_entrypoint_request_duration_seconds_count{job=\"traefik\"}[5m])) by (entrypoint)",
          "legendFormat": "{{ entrypoint }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Requests by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(traefik_service_requests_total{job=\"traefik\"}[5m])) by (service)",
          "legendFormat": "{{ service }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Open Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "traefik_entrypoint_open_connections{job=\"traefik\"}",
          "legendFormat": "{{ entrypoint }} - {{ method }}"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    }
  ]
}
