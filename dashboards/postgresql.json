{
  "__inputs": [],
  "__requires": [],
  "uid": "postgresql",
  "title": "PostgreSQL",
  "tags": ["postgresql", "database"],
  "editable": true,
  "refresh": "30s",
  "schemaVersion": 38,
  "timezone": "browser",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pg_stat_activity_count{job=\"postgres-exporter\"}",
          "legendFormat": "{{ datname }} - {{ state }}"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Transactions / s",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{job=\"postgres-exporter\"}[5m]) + rate(pg_stat_database_xact_rollback{job=\"postgres-exporter\"}[5m])",
          "legendFormat": "{{ datname }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Cache Hit Ratio",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pg_stat_database_blks_hit{job=\"postgres-exporter\"} / (pg_stat_database_blks_hit{job=\"postgres-exporter\"} + pg_stat_database_blks_read{job=\"postgres-exporter\"})",
          "legendFormat": "{{ datname }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Rows Operations / s",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_returned{job=\"postgres-exporter\"}[5m])",
          "legendFormat": "{{ datname }} returned"
        },
        {
          "expr": "rate(pg_stat_database_tup_fetched{job=\"postgres-exporter\"}[5m])",
          "legendFormat": "{{ datname }} fetched"
        },
        {
          "expr": "rate(pg_stat_database_tup_inserted{job=\"postgres-exporter\"}[5m])",
          "legendFormat": "{{ datname }} inserted"
        },
        {
          "expr": "rate(pg_stat_database_tup_updated{job=\"postgres-exporter\"}[5m])",
          "legendFormat": "{{ datname }} updated"
        },
        {
          "expr": "rate(pg_stat_database_tup_deleted{job=\"postgres-exporter\"}[5m])",
          "legendFormat": "{{ datname }} deleted"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Database Size",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pg_database_size_bytes{job=\"postgres-exporter\"}",
          "legendFormat": "{{ datname }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Deadlocks / s",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(pg_stat_database_deadlocks{job=\"postgres-exporter\"}[5m])",
          "legendFormat": "{{ datname }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      }
    }
  ]
}
